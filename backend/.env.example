# ─────────────────────────────────────────────
# Xisaabaati Backend — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# Firebase Admin SDK
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Alternatively, paste the entire service-account JSON as one line (Vercel-friendly):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...",...}

# Allowed frontend origins (comma-separated for multiple)
# Development:
# ALLOWED_ORIGINS=http://localhost:5173
# Production:
ALLOWED_ORIGINS=https://app.xisaabaati.so

# Admin WhatsApp number for payment confirmations (with country code, no +)
ADMIN_WHATSAPP=25261XXXXXXX
ADMIN_PHONE_DISPLAY=+252 61 XXX XXXX

# EVC Plus API (leave empty until credentials are provided)
EVC_API_KEY=
EVC_MERCHANT_ID=
EVC_API_URL=https://api.evcplus.com/v1

# Zaad API (leave empty until credentials are provided)
ZAAD_API_KEY=
ZAAD_MERCHANT_ID=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
