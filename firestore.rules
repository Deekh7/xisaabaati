rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function isOwner() { return request.auth.uid == resource.data.uid; }
    function isAdmin() { return request.auth.token.admin == true; }

    // ── users ────────────────────────────────────────────────────
    // Users read/write own profile only; admins can read any
    match /users/{userId} {
      allow read:  if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── invoices ─────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read:   if isAuth() && isOwner();
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isAuth() && isOwner();
    }

    // ── customers ────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:   if isAuth() && isOwner();
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isAuth() && isOwner();
    }

    // ── payments ─────────────────────────────────────────────────
    // Users can create and read their own payments
    // Only admins can update (approve/reject) payments
    match /payments/{paymentId} {
      allow read:   if isAuth() && (isOwner() || isAdmin());
      allow create: if isAuth() && request.auth.uid == request.resource.data.uid;
      allow update: if isAuth() && isAdmin();
      allow delete: if false; // never delete payment records
    }

    // ── adminNotifications ───────────────────────────────────────
    match /adminNotifications/{notifId} {
      allow read, write: if isAuth() && isAdmin();
    }

    // ── adminLogs ────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read, write: if isAuth() && isAdmin();
    }

    // ── messages (contact form) ──────────────────────────────────
    // Anyone can submit a contact form message (create only)
    match /messages/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'body']);
      allow read, update, delete: if isAuth() && isAdmin();
    }

    // ── plans ────────────────────────────────────────────────────
    // Anyone can read plan configs (pricing page)
    match /plans/{planKey} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── pages (CMS) ──────────────────────────────────────────────
    // Anyone can read CMS pages (about, privacy, terms)
    match /pages/{slug} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── catch-all: deny everything else ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
