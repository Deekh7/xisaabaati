rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function isOwner() { return request.auth.uid == resource.data.uid; }
    function isAdmin() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function ownsNew() { return request.auth.uid == request.resource.data.uid; }

    // ── users ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── sales ────────────────────────────────────────────────────
    match /sales/{saleId} {
      allow read:           if isAuth() && isOwner();
      allow create:         if isAuth() && ownsNew();
      allow update, delete: if isAuth() && isOwner();
    }

    // ── products ─────────────────────────────────────────────────
    match /products/{productId} {
      allow read:           if isAuth() && isOwner();
      allow create:         if isAuth() && ownsNew();
      allow update, delete: if isAuth() && isOwner();
    }

    // ── expenses ─────────────────────────────────────────────────
    match /expenses/{expenseId} {
      allow read:           if isAuth() && isOwner();
      allow create:         if isAuth() && ownsNew();
      allow update, delete: if isAuth() && isOwner();
    }

    // ── invoices (legacy) ─────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read:           if isAuth() && isOwner();
      allow create:         if isAuth() && ownsNew();
      allow update, delete: if isAuth() && isOwner();
    }

    // ── customers ────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read:           if isAuth() && isOwner();
      allow create:         if isAuth() && ownsNew();
      allow update, delete: if isAuth() && isOwner();
    }

    // ── payments ─────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isAuth() && (isOwner() || isAdmin());
      allow create: if isAuth() && ownsNew();
      allow update: if isAuth() && isAdmin();
      allow delete: if false;
    }

    // ── adminNotifications ───────────────────────────────────────
    match /adminNotifications/{notifId} {
      allow read, write: if isAuth() && isAdmin();
    }

    // ── adminLogs ────────────────────────────────────────────────
    match /adminLogs/{logId} {
      allow read, write: if isAuth() && isAdmin();
    }

    // ── messages (contact form) ──────────────────────────────────
    match /messages/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'body']);
      allow read, update, delete: if isAuth() && isAdmin();
    }

    // ── plans ────────────────────────────────────────────────────
    match /plans/{planKey} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── pages (CMS) ──────────────────────────────────────────────
    match /pages/{slug} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // ── catch-all: deny everything else ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
