# ─────────────────────────────────────────────
# Xisaabaati Frontend — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Firebase Web SDK Config
# Get from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Backend API URL
# Development:
# VITE_API_URL=http://localhost:3001
# Production (your Railway/Render/Cloud Run URL):
VITE_API_URL=https://api.xisaabaati.so

# Admin bootstrap — comma-separated emails that get role=admin on first signup.
# Set this BEFORE those accounts register.
VITE_BOOTSTRAP_ADMIN_EMAIL=admin@xisaabaati.com

# Admin WhatsApp number for payment follow-up (with country code, no spaces)
VITE_ADMIN_WHATSAPP=25261XXXXXXX
VITE_ADMIN_WHATSAPP_DISPLAY=+252 61 XXX XXXX
